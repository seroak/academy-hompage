# Playwright E2E 실행 시 playwright.config.ts의 webServer가 자동으로 주입하는 값들.
# 별도로 .env.e2e를 만들어 쓸 필요는 없지만, 수동으로 목 서버/브라우저 앱을 따로 띄워
# 디버깅할 때 참고용으로 문서화해 둔다.

# 목 API 서버(e2e/mock-server/server.ts)가 뜨는 포트
MOCK_API_PORT="4310"

# Next dev 서버가 이 값을 바라보도록 playwright.config.ts가 주입한다.
# 실백엔드(3000)나 평소 개발용 dev 서버(3001)와 절대 겹치지 않는 E2E 전용 값이다.
NEXT_PUBLIC_API_BASE_URL="http://localhost:4310"
NEXT_PUBLIC_SITE_URL="http://localhost:3410"
