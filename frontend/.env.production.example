# 로컬 운영 빌드에서는 frontend/.env.production으로 복사해서 채운다(커밋 금지).
# Vercel에서는 같은 이름을 Production 환경변수로 등록한 뒤 재배포한다.
# NEXT_PUBLIC_SITE_URL은 canonical, Open Graph, sitemap.xml, rss.xml의 절대 URL 기준이다.

NEXT_PUBLIC_API_BASE_URL="https://openmath.io.kr"
NEXT_PUBLIC_SITE_URL="https://api.openmath.io.kr"
NAVER_SITE_VERIFICATION=""
GOOGLE_SITE_VERIFICATION=""
