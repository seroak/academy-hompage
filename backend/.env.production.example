# backend/.env.production 으로 복사해서 채운다 (커밋 금지)
# DATABASE_URL은 docker-compose.prod.yml이 postgres 서비스 기준으로 자동 주입하므로 여기 적지 않는다.

PORT=3000
CORS_ORIGIN=https://example.com
BACKEND_PUBLIC_URL=https://api.example.com
FRONTEND_URL=https://example.com

JWT_SECRET=
JWT_EXPIRES_IN=1d
OAUTH_STATE_SECRET=

ADMIN_SEED_USERNAME=
ADMIN_SEED_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=학원 <no-reply@example.com>
