# backend/.env.production 으로 복사해서 채운다 (커밋 금지)
# DATABASE_URL은 docker-compose.prod.yml이 postgres 서비스 기준으로 자동 주입하므로 여기 적지 않는다.

PORT=3000
CORS_ORIGIN=https://example.com
BACKEND_PUBLIC_URL=https://api.example.com
FRONTEND_URL=https://example.com
# 프론트(apex 도메인)와 백엔드(api 서브도메인)가 세션 쿠키를 공유하려면 apex 도메인을 지정한다.
# 비워두면(로컬 개발 등) 쿠키가 요청 호스트에만 묶인다.
COOKIE_DOMAIN=example.com

JWT_SECRET=
JWT_EXPIRES_IN=1d
OAUTH_STATE_SECRET=

ADMIN_SEED_USERNAME=
ADMIN_SEED_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=생각을 여는 수학 <no-reply@openmath.io.kr>
# 새 수업 신청 접수 시 알림을 받을 관리자 이메일. 콤마로 여러 명 지정 가능.
ADMIN_NOTIFICATION_EMAIL=
