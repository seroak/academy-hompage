// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum OAuthProvider {
  GOOGLE
  KAKAO
  NAVER
}

model ParentUser {
  id               String                @id @default(cuid())
  email            String?               @unique
  name             String?
  passwordHash     String?
  socialAccounts   ParentSocialAccount[]
  authSessions     ParentAuthSession[]
  reservations     Reservation[]
  children         Child[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model Child {
  id               String            @id @default(cuid())
  parentUser       ParentUser        @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  parentUserId     String
  name             String
  age              Int
  reservations     Reservation[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([parentUserId])
}

model ParentSocialAccount {
  id                String        @id @default(cuid())
  provider          OAuthProvider
  providerAccountId String
  profileEmail      String?
  profileName       String?
  parentUser        ParentUser    @relation(fields: [parentUserId], references: [id])
  parentUserId      String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([provider, providerAccountId])
}

model ParentAuthSession {
  id           String     @id @default(cuid())
  code         String     @unique
  parentUser   ParentUser @relation(fields: [parentUserId], references: [id])
  parentUserId String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime   @default(now())
}

model ParentEmailVerification {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  token        String    @unique
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

enum ScheduleDayKind {
  CLASS
  HOLIDAY
  CLOSED
}

model ClassSchedule {
  id          String             @id @default(cuid())
  year        Int
  quarter     Int
  status      ScheduleStatus     @default(DRAFT)
  publishedAt DateTime?
  days        ClassScheduleDay[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([year, quarter])
}

model ClassScheduleDay {
  id          String          @id @default(cuid())
  schedule    ClassSchedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId  String
  date        String
  kind        ScheduleDayKind
  classMonth  String?
  note        String?

  @@unique([scheduleId, date])
  @@index([scheduleId])
}

enum ReservationStatus {
  WAITING
  GROUPED
  CANCELLED
}

enum ReservationGroupStatus {
  CONFIRMED
  EMPTY
}

model Reservation {
  id                String                     @id @default(cuid())
  childName         String
  childAge          Int
  child             Child?                    @relation(fields: [childId], references: [id], onDelete: SetNull)
  childId           String?
  parentName        String
  parentEmail       String
  parentPhone       String?
  preferredSlots    ReservationPreferredSlot[]
  note              String?
  status            ReservationStatus          @default(WAITING)
  group             ReservationGroup?          @relation(fields: [groupId], references: [id])
  groupId           String?
  groupSlots        ReservationGroupSlot[]
  requestedGroup    ReservationGroup?          @relation("RequestedGroup", fields: [requestedGroupId], references: [id], onDelete: SetNull)
  requestedGroupId  String?
  parentUser        ParentUser?                @relation(fields: [parentUserId], references: [id])
  parentUserId      String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model ReservationPreferredSlot {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String
  dayOfWeek     String
  startMinute   Int
  endMinute     Int

  @@unique([reservationId, dayOfWeek, startMinute, endMinute])
  @@index([dayOfWeek, startMinute, endMinute])
}

model ReservationGroup {
  id                  String                 @id @default(cuid())
  label               String
  status              ReservationGroupStatus @default(EMPTY)
  capacity            Int
  minAge              Int
  maxAge              Int
  scheduleDayOfWeek   String?
  scheduleStartMinute Int?
  scheduleEndMinute   Int?
  reservations        Reservation[]
  requestedBy         Reservation[]          @relation("RequestedGroup")
  slots               ReservationGroupSlot[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model ReservationGroupSlot {
  id            String           @id @default(cuid())
  group         ReservationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String
  reservation   Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String?
  dayOfWeek     String
  startMinute   Int
  endMinute     Int

  @@index([groupId])
  @@index([dayOfWeek, startMinute, endMinute])
}

model AdminNotification {
  id            String    @id @default(cuid())
  type          String
  title         String
  body          String
  reservationId String?
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([readAt])
  @@index([createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  CONSULTATION_BOOKED
  VISITED
  REGISTERED
  NO_RESPONSE
  DISQUALIFIED
}

enum ContactWindow {
  H13_15
  H15_18
  H18_20
}

model Lead {
  id                       String        @id @default(cuid())
  guardianName             String
  phone                    String
  childAge                 Int
  contactWindow            ContactWindow
  status                   LeadStatus    @default(NEW)
  utmSource                String?
  utmMedium                String?
  utmCampaign              String?
  utmContent               String?
  utmTerm                  String?
  fbclid                   String?
  landingPath              String?
  referrer                 String?
  privacyConsentVersion    String
  privacyConsentAt         DateTime
  analyticsConsent         Boolean
  marketingConsent         Boolean
  adminNote                String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@index([phone, createdAt])
  @@index([status, createdAt])
  @@index([utmCampaign, utmContent, createdAt])
}

model MarketingEvent {
  id           String   @id @default(cuid())
  eventId      String   @unique
  sessionId    String
  name         String
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  fbclid       String?
  landingPath  String?
  occurredAt   DateTime
  createdAt    DateTime @default(now())

  @@index([occurredAt])
  @@index([utmCampaign, utmContent, occurredAt])
  @@index([name, sessionId, occurredAt])
}

model MetaAdDailyInsight {
  id            String   @id @default(cuid())
  date          String
  accountId     String
  campaignId    String
  campaignName  String
  adSetId       String
  adSetName     String
  adId          String
  adName        String
  spendWon      Int
  impressions   Int
  linkClicks    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, adId])
  @@index([campaignId, date])
}

model MetaAdCreative {
  adId         String   @id
  imageUrl     String?
  thumbnailUrl String?
  updatedAt    DateTime @updatedAt
}

model MetaSyncState {
  id            String    @id
  isRunning     Boolean   @default(false)
  lastStartedAt DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
