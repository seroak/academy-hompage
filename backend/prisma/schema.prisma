// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum OAuthProvider {
  GOOGLE
  KAKAO
  NAVER
}

model ParentUser {
  id               String                @id @default(cuid())
  email            String?               @unique
  name             String?
  passwordHash     String?
  socialAccounts   ParentSocialAccount[]
  authSessions     ParentAuthSession[]
  reservations     Reservation[]
  levelTestResults LevelTestResult[]
  children         Child[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model Child {
  id               String            @id @default(cuid())
  parentUser       ParentUser        @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  parentUserId     String
  name             String
  age              Int
  reservations     Reservation[]
  levelTestResults LevelTestResult[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([parentUserId])
}

model ParentSocialAccount {
  id                String        @id @default(cuid())
  provider          OAuthProvider
  providerAccountId String
  profileEmail      String?
  profileName       String?
  parentUser        ParentUser    @relation(fields: [parentUserId], references: [id])
  parentUserId      String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([provider, providerAccountId])
}

model ParentAuthSession {
  id           String     @id @default(cuid())
  code         String     @unique
  parentUser   ParentUser @relation(fields: [parentUserId], references: [id])
  parentUserId String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime   @default(now())
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReservationStatus {
  WAITING
  GROUPED
  CANCELLED
}

enum ReservationGroupStatus {
  CONFIRMED
  CANCELLED
}

model Reservation {
  id                String                     @id @default(cuid())
  childName         String
  childAge          Int
  child             Child?                    @relation(fields: [childId], references: [id], onDelete: SetNull)
  childId           String?
  parentName        String
  parentEmail       String
  parentPhone       String?
  preferredSlots    ReservationPreferredSlot[]
  note              String?
  status            ReservationStatus          @default(WAITING)
  group             ReservationGroup?          @relation(fields: [groupId], references: [id])
  groupId           String?
  groupSlots        ReservationGroupSlot[]
  requestedGroup    ReservationGroup?          @relation("RequestedGroup", fields: [requestedGroupId], references: [id], onDelete: SetNull)
  requestedGroupId  String?
  parentUser        ParentUser?                @relation(fields: [parentUserId], references: [id])
  parentUserId      String?
  levelTestResult   LevelTestResult?           @relation(fields: [levelTestResultId], references: [id])
  levelTestResultId String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model ReservationPreferredSlot {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String
  dayOfWeek     String
  startMinute   Int
  endMinute     Int

  @@unique([reservationId, dayOfWeek, startMinute, endMinute])
  @@index([dayOfWeek, startMinute, endMinute])
}

model ReservationGroup {
  id                  String                 @id @default(cuid())
  label               String
  status              ReservationGroupStatus @default(CONFIRMED)
  capacity            Int
  minAge              Int
  maxAge              Int
  scheduleDayOfWeek   String?
  scheduleStartMinute Int?
  scheduleEndMinute   Int?
  reservations        Reservation[]
  requestedBy         Reservation[]          @relation("RequestedGroup")
  slots               ReservationGroupSlot[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model ReservationGroupSlot {
  id            String           @id @default(cuid())
  group         ReservationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String
  reservation   Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String?
  dayOfWeek     String
  startMinute   Int
  endMinute     Int

  @@index([groupId])
  @@index([dayOfWeek, startMinute, endMinute])
}

enum LevelTestQuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
}

model LevelTestQuestion {
  id                 String                @id @default(cuid())
  age                Int
  type               LevelTestQuestionType
  prompt             String
  promptImageUrl     String?
  choices            String[]              @default([])
  correctChoiceIndex Int?
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([age, active])
}

model LevelTestAgeConfig {
  age       Int      @id
  drawCount Int      @default(5)
  updatedAt DateTime @updatedAt
}

model LevelTestResult {
  id            String        @id @default(cuid())
  parentUser    ParentUser    @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  parentUserId  String
  childName     String
  childAge      Int
  child         Child?       @relation(fields: [childId], references: [id], onDelete: SetNull)
  childId       String?
  answers       Json
  score         Int?
  scorableCount Int?
  reservations  Reservation[]
  createdAt     DateTime      @default(now())

  @@index([parentUserId])
}
